# === GOOGLE API CREDENTIALS ===
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or use existing)
# 3. Enable these APIs: Google Sheets API, Google Docs API, Google Drive API
# 4. Go to Credentials > Create Credentials > Service Account
# 5. Download the JSON key file, save as "google-credentials.json" in this folder
# 6. Copy the service account email (looks like: xxx@project.iam.gserviceaccount.com)
# 7. Share your Google Sheets and Docs with that email (Editor access)

GOOGLE_CREDENTIALS_FILE=google-credentials.json

# === TWILIO WHATSAPP ===
# 1. Sign up at https://www.twilio.com/
# 2. Get a WhatsApp-enabled number from Twilio console
# 3. Set up WhatsApp sandbox for testing: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn

TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# === WHATSAPP NUMBERS ===
# Admin number (your number)
ADMIN_WHATSAPP=whatsapp:+91XXXXXXXXXX

# === FREE PERSISTENT STORAGE (via Google Drive) ===
# Render's free web service disk resets on every restart/redeploy, wiping
# data.json and server-config.json. To survive restarts without a paid
# Render disk:
# 1. Create a folder in your own Google Drive, e.g. "OJT Dashboard State"
# 2. Share that folder with your service account email (Editor access) -
#    the same email from your google-credentials.json / GOOGLE_CREDENTIALS_JSON
# 3. Open the folder, copy the folder ID from its URL
#    (https://drive.google.com/drive/folders/THIS_PART_IS_THE_ID)
# 4. Set it below
DRIVE_STATE_FOLDER_ID=your_drive_folder_id_here

# === SERVER ===
PORT=3848
